{
  "django": {
    "name": "Django",
    "keywords": ["SECRET_KEY", "DATABASE_URL", "DEBUG", "ALLOWED_HOSTS", "DJANGO_SETTINGS", "django_secret", "django_db"],
    "patterns": ["SECRET_KEY = '{value}'", "DATABASES['default']['PASSWORD']", "EMAIL_HOST_PASSWORD"]
  },
  "rails": {
    "name": "Ruby on Rails",
    "keywords": ["secret_key_base", "RAILS_MASTER_KEY", "DATABASE_URL", "RAILS_ENV", "REDIS_URL", "secret_token"],
    "patterns": ["secret_key_base: {value}", "ENV['DATABASE_URL']", "config.secret_key_base"]
  },
  "flask": {
    "name": "Flask",
    "keywords": ["SECRET_KEY", "FLASK_ENV", "DATABASE_URL", "SQLALCHEMY_DATABASE_URI", "WTF_CSRF_SECRET_KEY"],
    "patterns": ["app.secret_key = '{value}'", "SECRET_KEY = '{value}'", "SQLALCHEMY_DATABASE_URI = '{value}'"]
  },
  "laravel": {
    "name": "Laravel",
    "keywords": ["APP_KEY", "APP_SECRET", "DB_PASSWORD", "DB_USERNAME", "REDIS_PASSWORD", "MAIL_PASSWORD", "AWS_SECRET"],
    "patterns": ["APP_KEY=base64:{value}", "DB_PASSWORD={value}", "REDIS_PASSWORD={value}"]
  },
  "spring": {
    "name": "Spring Boot",
    "keywords": ["spring.datasource.password", "spring.datasource.url", "spring.security.oauth2.client.registration", "jwt.secret", "server.ssl.key"],
    "patterns": ["spring.datasource.password={value}", "server.ssl.key-store-password={value}", "jwt.secret={value}"]
  },
  "express": {
    "name": "Express.js",
    "keywords": ["SESSION_SECRET", "JWT_SECRET", "DB_PASSWORD", "MONGO_URI", "REDIS_URL", "COOKIE_SECRET"],
    "patterns": ["process.env.SESSION_SECRET", "process.env.JWT_SECRET", "process.env.MONGO_URI"]
  },
  "gin": {
    "name": "Go Gin",
    "keywords": ["GIN_SECRET", "JWT_SECRET", "DB_PASSWORD", "DSN", "MYSQL_DSN", "REDIS_PASSWORD"],
    "patterns": ["gin.Mode()", "os.Getenv(\"JWT_SECRET\")", "os.Getenv(\"DSN\")"]
  },
  "fastapi": {
    "name": "FastAPI",
    "keywords": ["SECRET_KEY", "DATABASE_URL", "POSTGRES_USER", "POSTGRES_PASSWORD", "JWT_SECRET", "API_KEY"],
    "patterns": ["SECRET_KEY = \"{value}\"", "DATABASE_URL = \"{value}\"", "API_KEY = \"{value}\""]
  },
  "aspnet": {
    "name": "ASP.NET Core",
    "keywords": ["ConnectionStrings__Default", "Jwt__Key", "Jwt__Issuer", "AzureAd__ClientSecret", "Authentication__Google__ClientSecret"],
    "patterns": ["\"ConnectionStrings:Default\": \"{value}\"", "\"Jwt:Key\": \"{value}\"", "\"AzureAd:ClientSecret\": \"{value}\""]
  },
  "nextjs": {
    "name": "Next.js",
    "keywords": ["NEXTAUTH_SECRET", "NEXTAUTH_URL", "DATABASE_URL", "JWT_SECRET", "AUTH_SECRET", "NEXT_PUBLIC_API_KEY"],
    "patterns": ["NEXTAUTH_SECRET={value}", "DATABASE_URL={value}", "NEXT_PUBLIC_API_KEY={value}"]
  }
}
